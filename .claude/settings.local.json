{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(bash *)",
      "Bash(powershell *)",
      "Bash(npx *)",
      "Bash(export *)",
      "Bash(*.venv/Scripts/python.exe *)",
      "Bash(Get-ChildItem *)",
      "Bash(Select-Object *)",
      "Bash(cp *)",
      "Bash(Test-Path *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(kill *)",
      "Skill(update-config)",
      "Bash(.\\\\backend\\\\.venv\\\\Scripts\\\\python.exe -c \"import sys; sys.path.insert\\(0, 'backend'\\); import prompt; import recommender; print\\('OK'\\)\")",
      "Bash(Sort-Object)",
      "Bash(pwd && ls -la \"c:\\\\Users\\\\Brad\\\\.claude\\\\\" 2>/dev/null || echo \"Need to check path\")",
      "Read(//c/Users/Brad/.claude\" 2>/dev/**)",
      "WebSearch",
      "Bash(netstat -ano)",
      "Bash(findstr \":8000\")",
      "Bash(.\\\\backend\\\\.venv\\\\Scripts\\\\python.exe -c \"import sys; sys.path.insert\\(0, 'backend'\\); import models; import cache; from routes import history, recommend; print\\('all imports OK'\\)\")",
      "Bash(dir \"C:\\\\Users\\\\Brad\\\\Desktop\\\\wine-recommendation-app\\\\backend\")",
      "Bash(.\\\\backend\\\\.venv\\\\Scripts\\\\python.exe -m pip install \"passlib[bcrypt]>=1.7.4\" \"PyJWT>=2.8.0\" \"email-validator>=2.1.0\")",
      "Bash(npx playwright *)",
      "Read(//tmp/**)"
    ],
    "additionalDirectories": [
      "c:\\Users\\Brad\\Desktop\\wine-recommendation-app\\docs",
      "\\tmp"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/hook.ps1"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/compact.ps1"
          }
        ]
      }
    ]
  }
}

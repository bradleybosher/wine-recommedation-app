{
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(bash *)",
      "Bash(powershell *)",
      "Bash(npx *)",
      "Bash(export *)",
      "Bash(*.venv/Scripts/python.exe *)",
      "Bash(Get-ChildItem *)",
      "Bash(Select-Object *)",
      "Bash(cp *)",
      "Bash(Test-Path *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(kill *)",
      "Skill(update-config)"
    ],
    "additionalDirectories": [
      "c:\\Users\\Brad\\Desktop\\wine-recommendation-app\\docs",
      "\\tmp"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/hook.ps1"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/compact.ps1"
          }
        ]
      }
    ]
  }
}

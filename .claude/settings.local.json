{
  "permissions": {
    "allow": [
      "Read(//mnt/c/Users/Brad/Desktop/**)",
      "Bash(bash sync_types.bat)",
      "Bash(powershell -NoProfile -Command \".\\\\sync_types.bat\")",
      "Bash(\".\\\\\\\\.venv\\\\\\\\Scripts\\\\\\\\python.exe\" -c \"import main\")",
      "Bash(ls -la \"c:\\\\Users\\\\Brad\\\\Desktop\\\\wine-recommendation-app\"/*.bat)",
      "Bash(ls -la /c/Users/Brad/Desktop/wine-recommendation-app/backend/*.py)"
    ]
  },
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/hook.ps1"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -File ~/.claude/read-once/compact.ps1"
          }
        ]
      }
    ]
  }
}

# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-...   # From console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6  # Optional; defaults to claude-sonnet-4-6 if unset

# Auth (JWT) — required.
# Generate a secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-me-with-a-long-random-hex-string
JWT_ALGORITHM=HS256   # Optional; defaults to HS256
JWT_EXPIRY_DAYS=7     # Optional; access-token lifetime in days, defaults to 7

# Test fixtures (off by default). When true, /recommend accepts test_fixture form field.
TEST_MODE=false
